---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';
import { site } from '../data/site';
---
<BaseLayout title="About | Bonus Creative" description="About Bonus Creative, an Oklahoma-based filmmaker-led studio focused on cinematic branded films, nonprofit storytelling, and event films." path="/about/">
  <section class="page-hero">
    <div class="container grid" style="gap:1rem; max-width:56rem;">
      <div class="eyebrow">About</div>
      <h1>I built Bonus Creative to keep the story close to the person telling it.</h1>
      <p>When you hire me, you are not getting passed from strategy to producer to shooter to editor. You are working with the same person all the way through.</p>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="panel founder-panel">
        <div class="founder-copy grid" style="gap:.75rem; width:100%; padding:1.25rem;">
          <div class="kicker">Founder portrait</div>
          <strong>Replace this panel with a real portrait as soon as it is available.</strong>
          <p class="small-note">Use a cinematic vertical image with strong contrast and restrained color.</p>
        </div>
      </div>
      <div class="grid" style="gap:1rem;">
        <h2>Story first. Process second. Ego last.</h2>
        <p>Bonus Creative is built around a simple idea: the fewer layers between the story and the storyteller, the better the work usually gets. That matters because good work often gets lost in the handoff.</p>
        <div class="checklist">
          <div>Award-winning writer, director, and filmmaker</div>
          <div>20 plus years of story-first work</div>
          <div>Oklahoma-rooted with a strong editorial eye</div>
          <div>Built for direct communication and lean execution</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cards-2">
      <div class="panel">
        <div class="grid" style="gap:.85rem;">
          <div class="eyebrow">Who it is for</div>
          <h3>Best fit clients</h3>
          <p>Brands, nonprofits, churches, founders, conferences, and teams with something real to say and no interest in looking like everybody else.</p>
        </div>
      </div>
      <div class="panel">
        <div class="grid" style="gap:.85rem;">
          <div class="eyebrow">Why this model works</div>
          <h3>Fewer handoffs. Cleaner decisions.</h3>
          <p>Working directly with one filmmaker protects the emotional logic of the project. The story stays more intact because it never gets diluted by committee.</p>
        </div>
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
