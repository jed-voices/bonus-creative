---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import FinalCta from '../components/FinalCta.astro';
import HeroReel from '../components/HeroReel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import { site, services, projects } from '../data/site';
---
<BaseLayout title="Bonus Creative | Oklahoma Video Producer" description={site.description} path="/">
  <section class="hero hero-premium">
    <div class="container hero-grid">
      <div class="hero-copy grid" style="gap:1.25rem;">
        <div class="eyebrow">{site.hero.eyebrow}</div>
        <h1>{site.hero.title}</h1>
        <p>{site.hero.copy}</p>
        <div class="btn-row">
          <a class="btn btn-primary" href="/work/">View Work</a>
          <a class="btn btn-secondary" href="/contact/">Start a Project</a>
        </div>
        <div class="hero-proof-row">
          {site.metrics.slice(0, 3).map((item) => (
            <div>
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-visual-stack">
        <HeroReel poster={site.hero.poster} posterAlt={site.hero.reelTitle} reelUrl={site.hero.videoUrl} />
      </div>
    </div>
    <div class="container trust-strip">
      {site.metrics.map((item) => (
        <div class="stat-card">
          <strong>{item.label}</strong>
          <p>{item.value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="grid" style="gap:1rem;">
        <div class="eyebrow">Direct collaboration</div>
        <h2>One filmmaker. Clear communication. Better work.</h2>
      </div>
      <div class="grid" style="gap:1rem;">
        <p>
          Projects move faster when the story is not handed from room to room. Strategy, filming, editing, and delivery stay aligned because the same person is carrying the thread.
        </p>
        <div class="checklist">
          <div>Direct communication from first call to final delivery</div>
          <div>Consistent visual language across concept, production, and edit</div>
          <div>Lean turnaround with fewer handoffs and clearer decisions</div>
          <div>Story-first work that feels cinematic without becoming overbuilt</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro eyebrow="Featured work" title="Different kinds of work. Same standard." copy="From mission-driven organizations to documentary projects and live events, each piece is built around clarity, restraint, and a point of view." />
      <div class="cards-3">
        {projects.map((project) => (
          <ProjectCard href={`/case-studies/${project.slug}/`} poster={project.poster} category={project.category} title={project.title} summary={project.summary} outcome={project.outcome} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro eyebrow="Services" title="What I actually help with." copy="The format changes. The job stays the same: find the point, make it feel human, and deliver something worth watching." />
      <div class="cards-3">
        {services.slice(0, 6).map((service) => (
          <div class="service-card">
            <strong>{service.title}</strong>
            <p>{service.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div class="grid" style="gap:1rem;">
        <div class="eyebrow">About</div>
        <h2>I built Bonus Creative to keep the story close to the person telling it.</h2>
        <p>
          The fewer layers between the story and the storyteller, the better the work usually gets. That is the point of the model.
        </p>
        <div class="btn-row">
          <a class="btn btn-secondary" href="/about/">More About the Approach</a>
        </div>
      </div>
      <div class="panel founder-panel">
        <div class="founder-copy grid" style="gap:.75rem; width:100%; padding:1.25rem;">
          <div class="kicker">Bo Wright</div>
          <strong>Award-winning writer, director, and filmmaker.</strong>
          <p>One line of sight from concept to final cut.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro eyebrow="Testimonials" title="How the work is supposed to feel." copy="For now these are guiding lines from the studio. Swap in approved client quotes when they are ready." />
      <div class="cards-3">
        {site.testimonials.map((item) => (
          <QuoteBlock quote={item.quote} person={item.person} role={item.role} />
        ))}
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
